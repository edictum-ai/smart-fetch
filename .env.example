# captatum hosted-flavor environment template.
# Copy to .env.local (gitignored) for local smoke, or inject into the ECS task.
# NEVER commit real values.

NODE_ENV=production
CAPTATUM_FLAVOR=hosted
HOST=127.0.0.1
PORT=3000

# OAuth (hosted) — REQUIRED for the hosted flavor (server fail-fast aborts without these)
OAUTH_ISSUER=
OAUTH_RESOURCE=
OAUTH_SIGNING_PRIVATE_JWK=
OAUTH_CONSENT_SIGNING_SECRET=
OAUTH_SIGNING_KEY_ID=
# Exact connector origins (scheme://host[:port]) or exact URLs. NEVER "*" (rejected).
OAUTH_REDIRECT_ALLOWLIST=

# Cloudflare Access (hosted) — REQUIRED for the hosted flavor. The OAuth consent
# login sits behind a Cloudflare Access app (path /oauth/authorize*) whose identity
# policy holds the email allowlist; the gateway verifies the Access JWT. A hosted
# boot FAILS CLOSED without all four.
CF_ACCESS_ENABLED=true
CF_ACCESS_AUDIENCE=
CF_ACCESS_ISSUER=https://<team>.cloudflareaccess.com
CF_ACCESS_CERTS_URL=https://<team>.cloudflareaccess.com/cdn-cgi/access/certs

# MCP inbound Host/Origin DNS-rebinding protection
MCP_ALLOWED_HOSTS=
MCP_ALLOWED_ORIGINS=

# OAuth-state store (hosted). DEFAULT = SQLite — a single file, no server. Set
# CAPTATUM_SQLITE_PATH (default ./data/captatum.sqlite; parent dir auto-created).
# One-click deploys (Railway/EC2/Mac Mini) need NO database. For scale, opt into
# TiDB (MySQL-compatible) by setting TIDB_HOST below (TLS/SSL_CA required).
CAPTATUM_SQLITE_PATH=./data/captatum.sqlite
# TiDB — optional scale path, used ONLY when TIDB_HOST is set
TIDB_HOST=
TIDB_PORT=4000
TIDB_DATABASE=captatum
TIDB_USER=captatum_rw
TIDB_PASSWORD=
TIDB_SSL_CA=

# Transform (optional). Free models work without a key but rate-limit faster.
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OLLAMA_BASE_URL=
# OLLAMA_MODEL=llama3.1
