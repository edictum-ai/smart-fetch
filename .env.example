# captatum hosted-flavor environment template.
# Copy to .env.local (gitignored) for local smoke, or inject into the ECS task.
# NEVER commit real values.

NODE_ENV=production
CAPTATUM_FLAVOR=hosted
HOST=127.0.0.1
PORT=3000

# OAuth (hosted) — REQUIRED for the hosted flavor (server fail-fast aborts without these)
OAUTH_ISSUER=
OAUTH_RESOURCE=
OAUTH_SIGNING_PRIVATE_JWK=
OAUTH_CONSENT_SIGNING_SECRET=
OAUTH_SIGNING_KEY_ID=
OAUTH_REDIRECT_ALLOWLIST=

# MCP inbound Host/Origin DNS-rebinding protection
MCP_ALLOWED_HOSTS=
MCP_ALLOWED_ORIGINS=

# TiDB OAuth-state store (hosted) — MySQL-compatible (e.g. TiDB); host via TIDB_HOST
TIDB_HOST=
TIDB_PORT=4000
TIDB_DATABASE=captatum
TIDB_USER=captatum_rw
TIDB_PASSWORD=
TIDB_SSL_CA=

# Transform (optional). Free models work without a key but rate-limit faster.
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OLLAMA_BASE_URL=
# OLLAMA_MODEL=llama3.1
